# File Purpose: Ignore rules for generated/local-only files.
# Key Mechanics: Keeps build artifacts, dependency folders, and large local analysis assets out of git history.

# System files
.DS_Store

# Dependencies
node_modules/

# Build output
dist/
coverage/

# TypeScript incremental artifacts
*.tsbuildinfo

# Generated JS from TS config (keep source .ts files)
vite.config.js
vite.config.d.ts

# Local analysis assets
analysis/*.zst
